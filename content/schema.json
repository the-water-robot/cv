{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pitilacqua/cv/content/schema.json",
  "title": "CV Schema",
  "type": "object",
  "required": ["meta", "person", "summary", "experience", "education", "skills", "projects", "languages", "beyond_work"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["language", "emphasis", "updated"],
      "additionalProperties": false,
      "properties": {
        "language": { "type": "string", "enum": ["it", "en"] },
        "emphasis": { "type": "string", "enum": ["leadership", "engineering", "hybrid"] },
        "updated":  { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "person": {
      "type": "object",
      "required": ["name", "title", "location", "email", "links"],
      "additionalProperties": false,
      "properties": {
        "name":     { "type": "string", "minLength": 1 },
        "title":    { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "email":    { "type": "string", "minLength": 1 },
        "links": {
          "type": "object",
          "required": ["linkedin", "github", "website"],
          "additionalProperties": false,
          "properties": {
            "linkedin": { "type": "string" },
            "github":   { "type": "string" },
            "website":  { "type": "string" }
          }
        }
      }
    },
    "summary": { "type": "string", "minLength": 1 },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["period", "role", "company", "location", "highlights"],
        "additionalProperties": false,
        "properties": {
          "period": {
            "type": "object",
            "required": ["from"],
            "additionalProperties": false,
            "properties": {
              "from": { "type": "string", "pattern": "^\\d{4}(-\\d{2})?$" },
              "to":   { "oneOf": [{ "type": "string", "pattern": "^\\d{4}(-\\d{2})?$" }, { "type": "null" }] }
            }
          },
          "role":     { "type": "string", "minLength": 1 },
          "company":  { "type": "string", "minLength": 1 },
          "location": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "highlights": {
            "type": "object",
            "required": ["leadership", "engineering"],
            "additionalProperties": false,
            "properties": {
              "leadership": { "type": "array", "items": { "type": "string" } },
              "engineering": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["degree", "institution", "period"],
        "additionalProperties": false,
        "properties": {
          "degree":      { "type": "string", "minLength": 1 },
          "institution": { "type": "string", "minLength": 1 },
          "period": {
            "type": "object",
            "required": ["from", "to"],
            "additionalProperties": false,
            "properties": {
              "from": { "type": "integer" },
              "to":   { "type": "integer" }
            }
          },
          "grade": { "type": "string" }
        }
      }
    },
    "skills": {
      "type": "object",
      "required": ["domains", "technologies"],
      "additionalProperties": false,
      "properties": {
        "domains": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "technologies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name":        { "type": "string", "minLength": 1 },
          "url":         { "type": "string" },
          "role":        { "type": "string" },
          "description": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "level"],
        "additionalProperties": false,
        "properties": {
          "name":  { "type": "string", "minLength": 1 },
          "level": { "type": "string", "minLength": 1 }
        }
      }
    },
    "beyond_work": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description"],
        "additionalProperties": false,
        "properties": {
          "title":       { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "url":         { "type": "string" },
          "period":      { "type": "string" }
        }
      }
    }
  }
}
