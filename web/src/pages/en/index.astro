---
import { getEntry } from "astro:content";
import { CVPage } from "../../components/CVPage";
import Header from "../../components/Header.astro";
import "../../styles/global.css";

const cv = await getEntry("cv", "cv.en");
if (!cv) throw new Error("cv.en.yaml not found");
const data = cv.data;

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const pdfUrl = `${base}cv_en.pdf`;

const labels = {
  filterLabels: { hybrid: "Both", leadership: "Leadership", engineering: "Engineering" },
  sectionExperience: "Experience",
  sectionSkills: "Skills",
  sectionDomains: "Domains",
  sectionEducation: "Education",
  sectionProjects: "Projects",
  sectionLanguages: "Languages",
  sectionBeyond: "Beyond Work",
  downloadPdf: "Download PDF",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{data.person.name} — CV</title>
    <meta name="description" content={`CV of ${data.person.name} — ${data.person.title}`} />
    <meta property="og:title" content={`${data.person.name} — CV`} />
    <meta property="og:description" content={`CV of ${data.person.name} — ${data.person.title}`} />
    <meta property="og:type" content="profile" />
    <link rel="alternate" hreflang="it" href={`${base}it/`} />
    <link rel="alternate" hreflang="en" href={`${base}en/`} />
    <link rel="canonical" href={`${base}en/`} />
  </head>
  <body>
    <Header lang="en" name={data.person.name} />
    <main>
      <CVPage client:load data={data} pdfUrl={pdfUrl} labels={labels} />
    </main>
    <footer>
      <div class="container footer-inner">
        <span>Updated {data.meta.updated}</span>
        <a href={base}>← Versione italiana</a>
      </div>
    </footer>
  </body>
</html>
